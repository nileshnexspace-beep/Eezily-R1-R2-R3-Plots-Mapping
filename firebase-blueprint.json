{
  "entities": {
    "Plot": {
      "title": "Plot",
      "description": "Public details of a land plot.",
      "type": "object",
      "properties": {
        "lat": { "type": "number", "description": "Latitude" },
        "lng": { "type": "number", "description": "Longitude" },
        "societyName": { "type": "string", "description": "Name of the society" },
        "unitNumber": { "type": "string", "description": "Unit number" },
        "size": { "type": "number", "description": "Size of the plot in Sqyd" },
        "pricePerSqyd": { "type": "number", "description": "Price per Sqyd" },
        "totalPrice": { "type": "number", "description": "Total price of the plot" },
        "locality": { "type": "string", "description": "Locality name" },
        "propertyTag": { "type": "string", "enum": ["Owner", "Broker"] },
        "details": { "type": "string", "description": "Description of the land" },
        "documents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "authorUid": { "type": "string", "description": "UID of the user who created the plot" }
      },
      "required": ["lat", "lng", "details", "authorUid"]
    },
    "PlotOwner": {
      "title": "PlotOwner",
      "description": "Private contact details of a land plot.",
      "type": "object",
      "properties": {
        "contactName": { "type": "string", "description": "Name of the contact" },
        "contactNumber": { "type": "string", "description": "Contact number" },
        "authorUid": { "type": "string", "description": "UID of the user who created the plot" }
      },
      "required": ["contactName", "contactNumber", "authorUid"]
    },
    "AllowedEmail": {
      "title": "AllowedEmail",
      "description": "Authorized team members who can access the dashboard.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "Email address of the team member" },
        "role": { "type": "string", "description": "Role of the team member (admin or member)" },
        "addedBy": { "type": "string", "description": "Email of the admin who added this user" },
        "createdAt": { "type": "string", "description": "When the user was added" }
      },
      "required": ["email", "role", "addedBy", "createdAt"]
    },
    "SharedLink": {
      "title": "SharedLink",
      "description": "Maps a readable slug to a list of plot IDs.",
      "type": "object",
      "properties": {
        "slug": { "type": "string", "description": "The human-readable part of the URL" },
        "plotIds": { "type": "array", "items": { "type": "string" }, "description": "The IDs of the plots to show" },
        "createdAt": { "type": "string", "description": "When the link was created" }
      },
      "required": ["slug", "plotIds", "createdAt"]
    }
  },
  "firestore": {
    "/plots/{plotId}": {
      "schema": { "$ref": "#/entities/Plot" },
      "description": "Public plot details"
    },
    "/plot_owners/{plotId}": {
      "schema": { "$ref": "#/entities/PlotOwner" },
      "description": "Private owner details, document ID matches the plotId"
    },
    "/allowed_emails/{email}": {
      "schema": { "$ref": "#/entities/AllowedEmail" },
      "description": "Stores authorized team members by email."
    },
    "/shared_links/{slug}": {
      "schema": { "$ref": "#/entities/SharedLink" },
      "description": "Maps a readable slug to a list of plot IDs."
    }
  }
}
